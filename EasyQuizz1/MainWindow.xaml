<Window x:Class="EazyQuizz.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EazyQuizz"
        Height="650"
        Width="950">

    <Grid Margin="10,-20,10,10">

        <TextBlock x:Name="txtLoggedUser"
                   Text="Neautentificat"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   FontWeight="Bold"
                   FontSize="14"
                   Margin="0,30,10,0"/>

        <TabControl Margin="0,30,0,0">

            <TabItem Header="Autentificare">
                <Grid>
                    <Border Width="350"
                            Padding="30"
                            BorderBrush="Gray"
                            BorderThickness="1"
                            CornerRadius="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                        <StackPanel>
                            <TextBlock Text="Autentificare"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,20"/>

                            <TextBlock Text="Nume student:" FontWeight="Bold"/>

                            <TextBox x:Name="txtStudentName"
                                     Height="30"
                                     Margin="0,5,0,15"/>

                            <TextBlock Text="Parola:" FontWeight="Bold"/>

                            <PasswordBox x:Name="txtPassword"
                                         Height="30"
                                         Margin="0,5,0,20"/>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">

                                <Button Content="Inregistrare"
                                        Width="120"
                                        Height="35"
                                        Margin="5"
                                        Click="Register_Click"/>

                                <Button Content="Login"
                                        Width="120"
                                        Height="35"
                                        Margin="5"
                                        Click="Login_Click"/>
                            </StackPanel>

                            <TextBlock x:Name="txtLoginStatus"
                                       FontWeight="Bold"
                                       Foreground="DarkGreen"
                                       TextAlignment="Center"
                                       Margin="0,20,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Quiz">
                <Grid Margin="20">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">

                        <Border x:Name="panelStartQuiz"
                                Padding="15"
                                BorderBrush="Gray"
                                BorderThickness="1"
                                CornerRadius="10"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="Alege domeniul:"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold"
                                           FontSize="16"
                                           Margin="0,0,10,0"/>

                                <ComboBox x:Name="cbQuizDomain"
                                          Width="180"
                                          Height="35"
                                          Margin="0,0,15,0"
                                          ItemsSource="{Binding DomainItems}"/>

                                <Button Content="Start Quiz"
                                        Width="130"
                                        Height="35"
                                        Click="StartQuiz_Click"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="panelQuestion"
                                Margin="0,20"
                                Padding="20"
                                BorderBrush="Gray"
                                BorderThickness="1"
                                CornerRadius="10"
                                Visibility="Collapsed">

                            <StackPanel>
                                <TextBlock x:Name="txtQuestion"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,20"/>

                                <RadioButton x:Name="rb1"
                                             GroupName="answers"
                                             FontSize="16"
                                             Margin="5"
                                             Visibility="Collapsed"/>

                                <RadioButton x:Name="rb2"
                                             GroupName="answers"
                                             FontSize="16"
                                             Margin="5"
                                             Visibility="Collapsed"/>

                                <RadioButton x:Name="rb3"
                                             GroupName="answers"
                                             FontSize="16"
                                             Margin="5"
                                             Visibility="Collapsed"/>

                                <RadioButton x:Name="rb4"
                                             GroupName="answers"
                                             FontSize="16"
                                             Margin="5"
                                             Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>

                    </Grid>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center">

                        <Button x:Name="btnAnswer"
                                Content="Raspunde"
                                Width="140"
                                Height="35"
                                Margin="5"
                                Click="Answer_Click"
                                Visibility="Collapsed"/>

                        <TextBlock x:Name="txtQuizStatus"
                                   Margin="20,10"
                                   FontWeight="Bold"
                                   FontSize="16"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Administrare intrebari">
                <Grid Margin="20">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBox x:Name="txtSearch"
                                 Height="30"
                                 Margin="0,0,0,10"/>

                        <Button Content="Cauta dupa text"
                                Height="35"
                                Margin="0,0,0,10"
                                Click="Search_Click"/>

                        <Button Content="Afiseaza toate"
                                Height="35"
                                Margin="0,0,0,10"
                                Click="ShowAllQuestions_Click"/>

                        <ListBox x:Name="lstQuestions"
                                 ItemsSource="{Binding Questions}"
                                 DisplayMemberPath="text"
                                 Height="420"
                                 SelectionChanged="lstQuestions_SelectionChanged"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Margin="20,0"
                            Padding="20"
                            BorderBrush="Gray"
                            BorderThickness="1"
                            CornerRadius="10">

                        <StackPanel>
                            <TextBlock Text="Text intrebare:" FontWeight="Bold"/>

                            <TextBox x:Name="txtQuestionAdmin"
                                     Height="30"
                                     Margin="0,5,0,10"/>

                            <TextBlock Text="Domeniu:" FontWeight="Bold"/>

                            <ComboBox x:Name="cbDomain"
                                      Height="30"
                                      Margin="0,5,0,10"
                                      ItemsSource="{Binding DomainItems}"/>

                            <TextBlock Text="Dificultate:" FontWeight="Bold"/>

                            <ComboBox x:Name="cbDifficulty"
                                      Height="30"
                                      Margin="0,5,0,20"
                                      ItemsSource="{Binding DifficultyItems}"/>

                            <TextBlock Text="Raspunsuri:"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Margin="0,0,0,10"/>

                            <TextBox x:Name="txtA1" Height="30" Margin="0,3"/>
                            <RadioButton x:Name="correct1" GroupName="correctAnswers" Content="Corect"/>

                            <TextBox x:Name="txtA2" Height="30" Margin="0,3"/>
                            <RadioButton x:Name="correct2" GroupName="correctAnswers" Content="Corect"/>

                            <TextBox x:Name="txtA3" Height="30" Margin="0,3"/>
                            <RadioButton x:Name="correct3" GroupName="correctAnswers" Content="Corect"/>

                            <TextBox x:Name="txtA4" Height="30" Margin="0,3"/>
                            <RadioButton x:Name="correct4" GroupName="correctAnswers" Content="Corect"/>

                            <WrapPanel HorizontalAlignment="Center"
                                       Margin="0,20,0,0">

                                <Button Content="Adauga"
                                        Width="100"
                                        Height="35"
                                        Margin="5"
                                        Click="AddQuestion_Click"/>

                                <Button Content="Modifica"
                                        Width="100"
                                        Height="35"
                                        Margin="5"
                                        Click="UpdateQuestion_Click"/>

                                <Button Content="Sterge"
                                        Width="100"
                                        Height="35"
                                        Margin="5"
                                        Click="DeleteQuestion_Click"/>

                                <Button Content="Salveaza"
                                        Width="100"
                                        Height="35"
                                        Margin="5"
                                        Click="SaveQuestions_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Scoruri">
                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="0,0,0,10">

                        <TextBlock Text="Cauta utilizator:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <TextBox x:Name="txtSearchUser"
                                 Width="200"
                                 Height="25"
                                 Margin="0,0,10,0"
                                 TextChanged="txtSearchUser_TextChanged"/>

                        <Button Content="Scor mare - mic"
                                Width="120"
                                Height="25"
                                Margin="0,0,10,0"
                                Click="SortDesc_Click"/>

                        <Button Content="Scor mic - mare"
                                Width="120"
                                Height="25"
                                Click="SortAsc_Click"/>
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,0,0,5">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Utilizator"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Grid.Column="0"/>

                        <TextBlock Text="Raspunsuri"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Grid.Column="1"/>

                        <TextBlock Text="Procent"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Grid.Column="2"/>

                        <TextBlock Text="Quizuri"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Grid.Column="3"/>
                    </Grid>

                    <ListBox x:Name="lstScores"
                             Grid.Row="2"
                             HorizontalContentAlignment="Stretch"/>
                </Grid>
            </TabItem>

        </TabControl>

    </Grid>
</Window>